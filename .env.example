# Optional production transcription. When omitted, the pipeline uses deterministic fallback captions.
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe-diarize

# Optional S3 IO for jobs using s3://bucket/key URIs.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rendering defaults.
TOPCODER_RENDER_WORKDIR=work
TOPCODER_OUTPUT_DIR=outputs
TOPCODER_TEMPLATE=topcoder-star
